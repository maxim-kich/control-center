{
  "name": "control-center",
  "version": "0.1.0",
  "private": false,
  "description": "Local Control Center for managing AI coding tasks and launching interactive provider CLIs.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/maxim-kich/control-center.git"
  },
  "homepage": "https://github.com/maxim-kich/control-center#readme",
  "bugs": {
    "url": "https://github.com/maxim-kich/control-center/issues"
  },
  "type": "commonjs",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "postinstall": "node scripts/postinstall.js",
    "start": "node server.js",
    "dev": "node --watch server.js",
    "macos-app": "bash scripts/create_macos_app.sh",
    "test": "node --test tests/*.test.js",
    "verify:public": "node scripts/verify_public.js",
    "verify:release": "npm test && npm run verify:public",
    "check-updates": "node scripts/update.js check",
    "update:dry-run": "node scripts/update.js update --dry-run"
  },
  "bin": {
    "control-center": "bin/control-center.js"
  },
  "dependencies": {
    "@xterm/addon-fit": "0.11.0",
    "@xterm/xterm": "6.0.0",
    "better-sqlite3": "^12.4.1",
    "express": "^5.1.0",
    "node-pty": "1.1.0",
    "ws": "8.21.0"
  }
}
